{
  "name": "ai-redteam",
  "version": "0.2.0",
  "description": "Deterministic, zero-ML red-teaming for LLM endpoints — prompt injection, jailbreaks, PII exfiltration, tool abuse and system-prompt leakage, scored against the OWASP LLM Top 10.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "llm",
    "security",
    "red-team",
    "owasp",
    "prompt-injection",
    "jailbreak",
    "ai-security"
  ],
  "bin": {
    "ai-redteam": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vitest": "^2.0.5"
  }
}
